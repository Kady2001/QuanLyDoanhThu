{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Chạy Web QuanLyDoanhThu",
      "type": "shell",
      "command": "node",
      "args": ["server.js"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*listening.*",
          "endsPattern": "^.*Server running.*"
        }
      },
      "runOptions": {
        "runOn": "default"
      }
    }
  ]
}
